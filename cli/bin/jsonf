#! /usr/bin/env node

const chunks = [];
process.stdin.on('data', (chunk) => chunks.push(chunk));
process.stdin.on('end', () => {
    const buffer = Buffer.concat(chunks);
    if (buffer.length > 0) {
        const json = JSON.parse(buffer.toString());
        console.dir(json, { depth: null, colors: true });
    }
});
