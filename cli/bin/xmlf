#!/usr/bin/env node

"use strict";

const prettyXml = require("xml-formatter");

const chunks = [];
process.stdin.on("data", (chunk) => chunks.push(chunk));
process.stdin.on("end", () => {
  const buffer = Buffer.concat(chunks);
  if (buffer.length > 0) {
    const xml = buffer.toString();
    console.log(prettyXml(xml, {}));
  }
});
